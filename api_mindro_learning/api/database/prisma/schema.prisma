
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(uuid())
  name            String
  email           String?    @unique
  profilePicture   String?
  joinedDate      DateTime?
  monthlyFee      Decimal? @db.Decimal(10, 2)
  nextDueDate     DateTime?
  mobilePhone     String?
  cpf             String? 
  birthDate       DateTime? 
  status          String?
  teacher         Teacher?   @relation(fields: [teacherId], references: [id])
  teacherId       String?
  courses         Course[]
  lessons         Lesson[]
  payments        PaymentHistory[]
  tasks           Task[]
  settings        Setting[]
  goals           Goal[]
  finances        Finance[]
  VerificationCode VerificationCode[]
}

model Teacher {
  id      String   @id @default(uuid())
  name    String
  email   String?  @unique
  users   User[]
  lessons Lesson[]
  tasks Task[]
  PaymentHistory PaymentHistory[]
}

model Language {
  id       String   @id
  name     String
  courses  Course[]
  lessons  Lesson[]
}

model Course {
  id         String   @id @default(uuid())
  title      String
  level      String?
  status     CourseStatus @default(REQUIRED)
  language   Language @relation(fields: [languageId], references: [id])
  languageId String
  user       User     @relation(fields: [userId], references: [id])
  userId     String
}

model Lesson {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  language   Language @relation(fields: [languageId], references: [id])
  languageId String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  teacherId  String
  date       DateTime
  time       DateTime @db.Time(0)
  status     String
}

model PaymentHistory {
  id       String   @id @default(uuid())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  date     DateTime
  fee          Decimal @db.Decimal(10, 2) @default(0)
  finalAmount   Decimal @db.Decimal(10, 2) @default(0)
  status   String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  teacherId    String
  transactionId String?
  method    String?
}

model Task {
  id           String   @id @default(uuid())
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  teacherId    String
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  title        String
  description  String?
  status       String
  progress     Int? 
  weight       Int?
  dueDate      DateTime?
  completedAt  DateTime?
}

model Setting {
  id     String   @id @default(uuid())
  user   User     @relation(fields: [userId], references: [id])
  userId String
  key    String
  value  String
}

model Goal {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  description String
  targetDate  DateTime?
  achieved    Boolean
}

model Finance {
  id       String   @id @default(uuid())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  type     String
  category String
  amount   Decimal @db.Decimal(10, 2)
  date     DateTime
  note     String?
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}


enum CourseStatus {
  REQUIRED
  ACTIVE
  PROGRESS
  FINISHED
}