# PostgreSQL connection string
DATABASE_URL=postgresql://admin:admin@postgres:5432/app?schema=public

# JWT — required for authentication
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ISSUER=mindro-api

# CORS — comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:3000

# OpenAI API key — required for AI features
OPENAI_API_KEY=sk-...

# Stripe secret key — required for payment processing
STRIPE_SECRET_KEY=sk_test_...
